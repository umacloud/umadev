# UmaDev - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# 注意：.env 文件不应提交到版本控制

# ==================== 应用配置 ====================
# Web API 监听端口
UMADEV_PORT=8000

# 语言设置 (zh | en)
UMADEV_LANG=zh

# ==================== API 认证 ====================
# 生产环境必须设置此变量。未设置时将生成一次性 key 并写入日志。
UMADEV_API_KEY=

# ==================== 日志 ====================
# 日志级别: DEBUG | INFO | WARNING | ERROR
UMADEV_LOG_LEVEL=info

# 日志格式: text | json (json 适合 ELK/Datadog 等日志聚合)
UMADEV_LOG_FORMAT=text

# ==================== API 限流 ====================
# 每个 IP 在时间窗口内的最大请求数
UMADEV_RATE_LIMIT=100

# 限流时间窗口 (秒)
UMADEV_RATE_WINDOW=60

# ==================== LLM 配置 ====================
# OpenAI API Key (用于文档生成、代码审查等)
OPENAI_API_KEY=

# ==================== 知识库 ====================
# 知识缓存 TTL (秒), 默认 1800 (30 分钟)
# UMADEV_KNOWLEDGE_CACHE_TTL=1800

# ==================== 质量门禁 ====================
# 质量门禁分数阈值 (0-100), 默认 90
# UMADEV_QUALITY_GATE=90

# ==================== CORS ====================
# 允许的跨域来源, 逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ==================== 数据库 (可选) ====================
# DATABASE_URL=postgresql://postgres:password@localhost:5432/umadev

# ==================== Redis (可选) ====================
# REDIS_URL=redis://localhost:6379
